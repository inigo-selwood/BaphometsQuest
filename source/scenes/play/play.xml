<scene name="play">
  <canvas-layer
    mode="world"
    name="world-layer"
  >
    <world name="world">
      <map
        name="map"
        texture="resources/textures/tileset.png"
        tileset="resources/maps/tileset.tsx"
      >
        <chunk
          data="resources/maps/chunks/overworld.tmx"
          position="[16, 16]"
        />
      </map>

      <player
        name="player"
        path="resources/textures/tileset.png"
        position="[80, 72]"
        region="[96, 88, 8, 8]"
        speed="64"
        step="8"
      >
        <camera
          name="camera"
          position="[4, 4]"
        />
      </player>

      <select-mode-icon
        active="false"
        name="selection-cursor"
        path="resources/textures/tileset.png"
        position="[80, 72]"
        region="[104, 16, 8, 8]"
      >
        <mode
          name="select"
          region="[112, 40, 8, 8]"
        />

        <mode
          name="sword"
          region="[96, 40, 8, 8]"
        />

        <mode
          name="axe"
          region="[104, 40, 8, 8]"
        />

        <mode
          name="bow"
          region="[96, 48, 8, 8]"
        />

        <mode
          name="magic"
          region="[112, 48, 8, 8]"
        />
      </select-mode-icon>
    </world>
  </canvas-layer>

  <canvas-layer
    mode="screen"
    name="screen-layer"
  >
    <import path="components/status_bar.xml" />

    <textbox
      awaiting-input="true"
      colour="#20283dff"
      cursor-path="resources/textures/tileset.png"
      cursor-region="[96, 16, 8, 8]"
      font="resources/fonts/04B_03.TTF"
      font-size="8"
      name="textbox"
      size="[0, 0, 160, 32]"
      text="I should find the temple before night falls."
    />

    <import path="components/pause_menu.xml" />
  </canvas-layer>
</scene>
