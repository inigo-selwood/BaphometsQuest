<scene name="play">
  <canvas-layer
    mode="world"
    name="world-layer"
  >
    <world name="world">
      <map
        name="map"
        texture="resources/textures/tileset.png"
        tileset="resources/maps/tileset.tsx"
      >
        <chunk
          data="resources/maps/chunks/overworld.tmx"
          position="[16, 16]"
        />
      </map>

      <player
        name="player"
        path="resources/textures/tileset.png"
        position="[80, 72]"
        region="[96, 88, 8, 8]"
        speed="64"
        step="8"
      >
        <camera
          name="camera"
          position="[4, 4]"
        />
      </player>
    </world>
  </canvas-layer>

  <canvas-layer
    mode="screen"
    name="screen-layer"
  >
    <box
      colour="#20283dff"
      name="hud"
      position="[0, 0]"
      size="[0, 0, 160, 8]"
    >
      <image
        name="heart-icon"
        path="resources/textures/tileset.png"
        position="[8, 0]"
        region="[112, 16, 8, 8]"
      />

      <label
        colour="#ffffffff"
        font="resources/fonts/04B_03.TTF"
        font-size="8"
        name="health-value"
        position="[18, 1]"
        text="000"
      />

      <image
        name="dollar-icon"
        path="resources/textures/tileset.png"
        position="[40, 0]"
        region="[120, 16, 8, 8]"
      />

      <label
        colour="#ffffffff"
        font="resources/fonts/04B_03.TTF"
        font-size="8"
        name="money-value"
        position="[48, 1]"
        text="0000"
      />
    </box>

    <textbox
      awaiting-input="true"
      colour="#20283dff"
      cursor-path="resources/textures/tileset.png"
      cursor-region="[96, 16, 8, 8]"
      font="resources/fonts/04B_03.TTF"
      font-size="8"
      name="textbox"
      size="[0, 0, 160, 32]"
      text="I should find the temple before night falls."
    />

    <box
      active="false"
      colour="#20283dff"
      name="pause-overlay"
      position="[0, 0]"
      size="[0, 0, 160, 120]"
    >
      <label
        colour="#ffffffff"
        font="resources/fonts/Early GameBoy.ttf"
        font-size="8"
        justification="centre"
        name="pause-title"
        position="[80, 28]"
        text="paused"
      />

      <menu
        colour="#ffffffff"
        cursor-offset="12"
        cursor-path="resources/textures/tileset.png"
        cursor-region="[104, 16, 8, 8]"
        font="resources/fonts/Early GameBoy.ttf"
        font-size="8"
        line-height="12"
        name="pause-menu"
        position="[48, 52]"
      >
        <option
          tag="inventory"
          text="Inventory"
        />

        <option
          tag="stats"
          text="Stats"
        />

        <option
          tag="save"
          text="Save"
        />

        <option
          tag="main-menu"
          text="Main Menu"
        />
      </menu>
    </box>

    <box
      active="false"
      colour="#20283dff"
      name="save-confirmation"
      position="[0, 0]"
      size="[0, 0, 160, 120]"
    >
      <label
        colour="#ffffffff"
        font="resources/fonts/Early GameBoy.ttf"
        font-size="8"
        justification="centre"
        name="save-title"
        position="[80, 48]"
        text="save game?"
      />

      <menu
        colour="#ffffffff"
        cursor-offset="12"
        cursor-path="resources/textures/tileset.png"
        cursor-region="[104, 16, 8, 8]"
        font="resources/fonts/Early GameBoy.ttf"
        font-size="8"
        line-height="12"
        name="save-menu"
        position="[56, 76]"
      >
        <option
          tag="yes"
          text="Yes"
        />

        <option
          tag="back"
          text="Back"
        />
      </menu>
    </box>
  </canvas-layer>
</scene>
